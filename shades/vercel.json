{
    "version": 2,
    "framework": "vite",
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "installCommand": "npm install --legacy-peer-deps",
    "devCommand": "npm run dev",
    "rewrites": [
        {
            "source": "/api/paystack/:path*",
            "destination": "/api/paystack.js"
        },
        {
            "source": "/api/:path*",
            "destination": "/api/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "functions": {
        "api/index.js": {
            "maxDuration": 60,
            "memory": 2048
        },
        "api/paystack.js": {
            "maxDuration": 60,
            "memory": 2048
        }
    },
    "regions": [
        "iad1"
    ],
    "env": {
        "VITE_PAYSTACK_PUBLIC_KEY": "pk_test_a68e26ef9e1637c263b49bc49cdef6e18cb282f9",
        "PAYSTACK_SECRET_KEY": "sk_test_bde739aec1a54f5266a40fa1ef1d1ed4ef12e825",
        "FRONTEND_URL": "https://shades-ruddy.vercel.app",
